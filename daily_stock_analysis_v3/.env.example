# Daily Stock Analysis v3.0 - Environment Configuration
# Copy this file to .env and fill in your values

# ===================================
# Application Settings
# ===================================
APP_NAME=Daily Stock Analysis
APP_VERSION=3.0.0-alpha
DEBUG=false
LOG_LEVEL=INFO

# ===================================
# Database Configuration
# ===================================
# SQLite (development)
DATABASE_URL=sqlite:///./data/stock_analysis.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/stock_analysis

DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ===================================
# Cache Configuration
# ===================================
CACHE_ENABLED=true
CACHE_BACKEND=memory
# CACHE_BACKEND=redis
# REDIS_URL=redis://localhost:6379/0
CACHE_DEFAULT_TTL=300
CACHE_MAX_SIZE=1000

# ===================================
# LLM/AI Configuration
# ===================================
LLM_PROVIDER=gemini
# Options: gemini, openai, deepseek, anthropic, ollama, aihubmix

LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192
LLM_TIMEOUT=30
LLM_RETRY_ATTEMPTS=3

# API Keys (set at least one)
GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# AIHUBMIX_KEY=your-aihubmix-key

# Custom API endpoint (optional)
# LLM_BASE_URL=https://api.example.com/v1

# ===================================
# API Server Configuration
# ===================================
API_HOST=0.0.0.0
API_PORT=8081
API_CORS_ORIGINS=*
API_RATE_LIMIT=60
API_ENABLE_AUTH=true

# ===================================
# Notification Configuration
# ===================================
NOTIFICATION_ENABLED=false
# NOTIFICATION_CHANNELS=telegram,discord,email

# Telegram
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# Discord
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Email
# EMAIL_SMTP_SERVER=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SENDER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# ===================================
# Analysis Configuration
# ===================================
REPORT_LANGUAGE=en
# Options: en, zh

REPORT_TYPE=full
# Options: simple, full, brief

ANALYSIS_MAX_WORKERS=3
ANALYSIS_ENABLE_NEWS=true
ANALYSIS_NEWS_MAX_AGE_DAYS=3
ANALYSIS_ENABLE_CHIP=true
ANALYSIS_BIAS_THRESHOLD=5.0

# ===================================
# Stock List
# ===================================
STOCK_LIST=600519,300750,AAPL,TSLA,NVDA
